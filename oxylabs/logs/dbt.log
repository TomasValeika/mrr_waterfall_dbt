  create  table "mydb"."silver"."silver_account_month_mrr__dbt_tmp"
  
  
    as
  
  (
    with
    min_max_month as (

        select
            date_trunc('month', min(start_date))::date as min_month,
            date_trunc('month', max(coalesce(end_date, current_date)))::date
            as max_month
        from "mydb"."silver"."silver_subscriptions"

    ),

    month_range as (

        select
            generate_series(min_month, max_month, interval '1 month')::date
            as month_start
        from min_max_month

    ),

    subscription_months as (

        select
            m.month_start,
            s.account_id,
            s.subscription_id,
            s.plan_tier,
            s.mrr_amount,
            s.is_trial,
            s.start_date,
            s.end_date
        from month_range m
        join
            "mydb"."silver"."silver_subscriptions" s
            on m.month_start >= date_trunc('month', s.start_date)::date
            and (
                s.end_date is null
                or m.month_start <= date_trunc('month', s.end_date)::date
            )

    ),

    account_month_mrr as (

        select month_start, account_id, sum(mrr_amount) as mrr
        from subscription_months
        where coalesce(is_trial, false) = false
        group by month_start, account_id

    )

select month_start, account_id, mrr
from account_month_mrr
  );
  
